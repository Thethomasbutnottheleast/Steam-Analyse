import webbrowser
import os
file_path = 'mca_3d_clustering.html'
abs_path = os.path.realpath(file_path)
webbrowser.open_new_tab(f'file://{abs_path}')


# Code to generate html file

import plotly.graph_objects as go
import plotly.io as pio
import string

# --- Prepare data ---
df_clusters.loc[active_row_coord.index, "kmeans mini 8"] = final_labels
df = active_row_coord.copy()

df["kmeans"] = df_clusters["kmeans"].values
df["kmeans full"] = df_clusters["kmeans full"].values
df["kmeans mini 3"] = df_clusters["kmeans mini 3"].values
df["kmeans mini 8"] = df_clusters["kmeans mini 8"].values

# --- List of variables for dropdown ---
variables = [
    "kmeans",
    "kmeans full",
    "kmeans mini 3",
    "kmeans mini 8"
]

initial_var = "kmeans mini 8"

fig = go.Figure()

trace_info = []

# --- Create one trace per cluster for each clustering variable ---
for var in variables:
    clusters = sorted(df[var].dropna().astype(str).unique())

    for cl in clusters:
        mask = df[var].astype(str) == cl

        fig.add_trace(go.Scatter3d(
            x=df.loc[mask, 0],
            y=df.loc[mask, 1],
            z=df.loc[mask, 2],
            mode="markers",
            marker=dict(
                size=3,
                opacity=0.55
            ),
            name=f"{cl}",
            legendgroup=f"{var}_{cl}",
            text=df.loc[mask, var].astype(str),
            hovertemplate=f"{var}: %{{text}}<extra></extra>",
            visible=(var == initial_var)
        ))

        trace_info.append((var, cl))

# --- Dropdown to choose clustering variable ---
buttons = []

for var in variables:
    visible = [trace_var == var for trace_var, trace_cl in trace_info]

    buttons.append(
        dict(
            label=var,
            method="update",
            args=[
                {"visible": visible},
                {
                    "title": f"Interactive 3D Steam Market Clusters — colored by {var}"
                }
            ]
        )
    )

fig.update_layout(
    updatemenus=[
        dict(
            buttons=buttons,
            direction="down",
            showactive=True,
            x=0.02,
            y=0.98
        )
    ],
    title=f"Interactive 3D Steam Market Clusters — colored by {initial_var}",
    scene=dict(
        xaxis_title="Dim 0",
        yaxis_title="Dim 1",
        zaxis_title="Dim 2"
    ),
    width=1100,
    height=800,
    legend_title="Cluster"
)

fig.write_html(
    "mca_3d_clustering.html",
    include_plotlyjs="cdn",
    full_html=True
)





