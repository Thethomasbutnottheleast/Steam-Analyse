        df_clusters
        .groupby("kmeans mini 8")[var]
        .value_counts(normalize=True)
        .unstack()
        .fillna(0)
    )
    
    dist.plot(kind="bar", stacked=True, ax=axes[i])
    
    axes[i].set_title(title)
    axes[i].set_xlabel("kmeans")
    axes[i].set_ylabel("Proportion")
    axes[i].tick_params(axis='x', rotation=0)

plt.tight_layout()
plt.show()





inertia_cah = []
ch_cah = []
db_cah = []
silhouette_cah = []
cluster_sizes = []

K_range = range(2, 15)

for k in K_range:
    # Cut CAH tree into k final groups
    center_groups = fcluster(
        Z,
        t=k,
        criterion="maxclust"
    ) - 1
    
    # Assign each original game to the CAH group of its KMeans centroid
    final_labels = center_groups[reskmeansmini]
    
    # Inertia-like criterion for final CAH groups
    total_inertia = 0
    
    for cluster_id in np.unique(final_labels):
        X_cluster = X_scaled[final_labels == cluster_id]
        centroid = X_cluster.mean(axis=0)
        total_inertia += np.sum((X_cluster - centroid) ** 2)
    
    inertia_cah.append(total_inertia)
    
    # Validation scores
    ch_cah.append(calinski_harabasz_score(X_scaled, final_labels))
    db_cah.append(davies_bouldin_score(X_scaled, final_labels))
    
    # Sampled silhouette to avoid memory problem
    idx = np.random.choice(len(X_scaled), size=min(5000, len(X_scaled)), replace=False)
    
    silhouette_cah.append(silhouette_score(X_scaled[idx, :], final_labels[idx]))
    
    # Store min/max cluster size
    counts = pd.Series(final_labels).value_counts()
    cluster_sizes.append({
        "k": k,
        "min_size": counts.min(),
        "max_size": counts.max()
    })


fig, axes = plt.subplots(2, 2, figsize=(12, 10))

# Inertia
axes[0, 0].plot(K_range, inertia_cah, marker='o')
axes[0, 0].set_xlabel("k")
axes[0, 0].set_ylabel("Inertia")
axes[0, 0].grid()

# Calinski-Harabasz
axes[0, 1].plot(K_range, ch_cah, marker='o')
axes[0, 1].set_xlabel("k")
axes[0, 1].set_ylabel("Calinski-Harabasz")
axes[0, 1].grid()

# Davies-Bouldin
axes[1, 0].plot(K_range, db_cah, marker='o')
axes[1, 0].set_xlabel("k")
axes[1, 0].set_ylabel("Davies-Bouldin")
axes[1, 0].grid()

# Silhouette
axes[1, 1].plot(K_range, silhouette_cah, marker='o')
axes[1, 1].set_xlabel("k")
axes[1, 1].set_ylabel("Silhouette")
axes[1, 1].grid()

plt.tight_layout()
plt.show()









