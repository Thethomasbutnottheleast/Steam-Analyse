# Transform price to qualitative for MCA

def price_category(p):
    if p == 0:
        return "free"
    elif p < 15:
        return "cheap"
    elif p < 40:
        return "mid"
    else:
        return "expensive"
order = ["free","cheap", "mid", "expensive"]
data["Price category"] = data["Price"].apply(price_category)


# Group the modalities of owners to avoid rare modalities

def regroup_owner(x):
    low = int(x.split(" - ")[0])
    if low < 1000000:
        return x
    else:
        return "> 1000000"

data["Owners group"] = data["Estimated owners"].apply(regroup_owner)
order = [
    "0 - 0",
    "0 - 20000",
    "20000 - 50000",
    "50000 - 100000",
    "100000 - 200000",
    "200000 - 500000",
    "500000 - 1000000",
    "> 1000000"
]





