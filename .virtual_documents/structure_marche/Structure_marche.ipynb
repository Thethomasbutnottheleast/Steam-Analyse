df_clusters["Realistics"] = ((df_clusters["Simulation"] + 
                                   df_clusters["Sports"])>0).astype(int) - ((df_clusters["Adventure"] + 
                                   df_clusters["Action"])>0).astype(int)
df_clusters["Strat vs Act"] = (df_clusters["Strategy"] - 
                                   df_clusters["Action"])
df_clusters["mixed"] = (df_clusters[list_rare].sum(axis=1) > 0).astype(int)

df_clusters["Indie Casual"] = df_clusters["Indie"] + df_clusters["Casual"]
df_clusters["Sports Racing"] = (df_clusters["Sports"] + 
                                   df_clusters["Racing"])
df_clusters['Action vs Casual'] = df_clusters["Action"] - df_clusters["Casual"]


#####
# To view the plot, open mca_3d_kmeans.html
#####
import plotly.graph_objects as go
import plotly.io as pio

# --- Prepare data ---
df = active_row_coord.copy()

df["Action"] = df_clusters["Action"].values
df["Sports Racing"] = df_clusters["Sports Racing"].values
df["Casual"] = df_clusters["Casual"].values
df["Simulation"] = df_clusters["Simulation"].values
df["Simulation vs Adventure"] = df_clusters["Simulation"].values - df_clusters["Adventure"].values
df["RPG"] = df_clusters["RPG"].values
df["MMO"] = df_clusters["Massively Multiplayer"].values
df["Strat vs Act"] = df_clusters["Strat vs Act"].values
df["Action vs Casual"] = df_clusters["Action vs Casual"].values
df["Strategy"] = df_clusters["Strategy"].values
# --- Helper: encode categorical to numbers ---
def encode(series):
    return series.astype("category").cat.codes

# --- Helper: create readable hover text ---
def make_hover(var_name):
    return (
        f"{var_name}: " + "%{text}<extra></extra>"
    )

# --- List of variables for dropdown ---
variables = [
    "Sports Racing",
    "Action",
    "Simulation",
    "Simulation vs Adventure",
    "RPG",
    "MMO",
    'Casual',
    "Action vs Casual",
    'Strategy'
]

# --- Initial variable ---
initial_var = "Sports Racing"

fig = go.Figure()

fig.add_trace(go.Scatter3d(
    x=df[0],
    y=df[1],
    z=df[2],
    mode="markers",
    marker=dict(
        size=3,
        color=encode(df[initial_var]),
        colorscale="Viridis",
        showscale=True
    ),
    text=df[initial_var].astype(str),
    hovertemplate=make_hover(initial_var)
))

# --- Dropdown buttons ---
buttons = []

for var in variables:
    buttons.append(
        dict(
            label=var,
            method="update",
            args=[
                {
                    "marker.color": [encode(df[var])],
                    "text": [df[var].astype(str)],
                    "hovertemplate": [make_hover(var)]
                },
                {
                    "title": f"Interactive 3D Steam Market Clusters — colored by {var}"
                }
            ]
        )
    )

fig.update_layout(
    updatemenus=[
        dict(
            buttons=buttons,
            direction="down",
            showactive=True,
            x=0.02,
            y=0.98
        )
    ]
)

fig.update_layout(
    title=f"Interactive 3D Steam Market Clusters — colored by {initial_var}",
    scene=dict(
        xaxis_title="Dim 0",
        yaxis_title="Dim 1",
        zaxis_title="Dim 2"
    ),
    width=1100,
    height=800
)

fig.write_html(
    "mca_3d.html",
    include_plotlyjs="cdn",
    full_html=True
)


